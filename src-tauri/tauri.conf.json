{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "JustOne AI",
  "version": "0.1.0",
  "identifier": "ai.justone.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "JustOne AI",
        "width": 1280,
        "height": 800,
        "minWidth": 960,
        "minHeight": 600,
        "center": true,
        "resizable": true,
        "decorations": true,
        "transparent": false,
        "visible": true,
        "alwaysOnTop": false
      }
    ],
    "security": {
      "csp": null
    },
    "macOSPrivateApi": true
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": [],
    "externalBin": [],
    "copyright": "",
    "category": "Productivity",
    "shortDescription": "Personal priority alignment powered by AI",
    "longDescription": "JustOne AI helps you stay aligned with your long-term vision by distilling your daily tasks into a 1-3-5 priority framework, powered by Gemini AI.",
    "linux": {},
    "macOS": {
      "signingIdentity": null,
      "entitlements": null,
      "providerShortName": null,
      "dmg": {}
    },
    "windows": {
      "certificateThumbprint": null,
      "digestAlgorithm": "sha256",
      "timestampUrl": ""
    }
  },
  "plugins": {
    "shell": {
      "open": true
    }
  }
}
